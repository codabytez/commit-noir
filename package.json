{
  "name": "commit-noir",
  "displayName": "Commit Noir — Git Commit Quality Guard",
  "description": "Terminal Noir pre-commit hook scanner with VS Code UI",
  "version": "1.0.1",
  "publisher": "codabytez",
  "license": "MIT",
  "icon": "media/icon.png",
  "keywords": [
    "git",
    "commit",
    "pre-commit",
    "hook",
    "secrets",
    "linter",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/codabytez/commit-noir.git"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commit-noir.showResult",
        "title": "Commit Noir: Show Last Commit Score",
        "icon": "$(git-commit)"
      },
      {
        "command": "commit-noir.installHook",
        "title": "Commit Noir: Install Git Hook"
      },
      {
        "command": "commit-noir.uninstallHook",
        "title": "Commit Noir: Uninstall Git Hook"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "commit-noir.showResult",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "commit-noir.showResult",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Commit Noir",
      "properties": {
        "commitNoir.scoreThreshold": {
          "type": "number",
          "default": 70,
          "description": "Minimum commit score (0–100). Commits below this are blocked."
        },
        "commitNoir.blockOnFail": {
          "type": "boolean",
          "default": true,
          "description": "If false, hook warns but never blocks commits."
        },
        "commitNoir.maxFileSizeKB": {
          "type": "number",
          "default": 500,
          "description": "Files larger than this (in KB) are flagged as oversized."
        },
        "commitNoir.ignorePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "*.lock",
            "dist/",
            "build/",
            "*.min.js"
          ],
          "description": "Glob patterns to exclude from scanning."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^5.3.0"
  }
}
